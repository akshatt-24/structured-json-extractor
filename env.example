# ─────────────────────────────────────────────
#  structured-json-extractor — environment config
# ─────────────────────────────────────────────

# Get your free API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Primary model
MODEL_NAME=meta-llama/llama-3.3-70b-instruct:free

# Fallback models tried in order when primary is rate-limited (comma-separated)
# Check active models at: https://openrouter.ai/models?q=:free
FALLBACK_MODELS=meta-llama/llama-3.1-8b-instruct:free,google/gemma-2-9b-it:free,qwen/qwen-2.5-7b-instruct:free,deepseek/deepseek-r1-0528:free

# Required by OpenRouter — requests without these are silently rejected (403)
# before being logged, causing "Last Used: Never" on the API key page.
HTTP_REFERER=http://localhost:8000
APP_TITLE=structured-json-extractor

MAX_RETRIES=3
LOG_LEVEL=INFO
